# Django Configuration
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=billing_v2_db
DB_USER=billing_user
DB_PASSWORD=billing_password
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_PASSWORD=220961

# Celery Configuration
CELERY_BROKER_URL=redis://:220961@redis:6379/0
CELERY_RESULT_BACKEND=redis://:220961@redis:6379/0

# Email Configuration (Brevo/Sendinblue)
BREVO_API_KEY=your_brevo_api_key_here

# AI Configuration (Google GenAI)
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# Application Settings
TIME_ZONE=Africa/Johannesburg
LANGUAGE_CODE=en-us

# Cloudflare Settings (if using Cloudflare proxy)
USE_X_FORWARDED_HOST=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True

# Optional: Sentry Error Tracking
# SENTRY_DSN=https://your-sentry-dsn
